# Upstream sync harness — copy to .sandcastle/.env for local runs.
# In GitHub Actions these are injected from repository secrets.

# Default agent provider: anthropic | openai
UPSTREAM_SYNC_AGENT=anthropic

# Anthropic (default) — parent orchestrator + child cluster agents
ANTHROPIC_API_KEY=
UPSTREAM_SYNC_ANTHROPIC_PARENT_MODEL=claude-opus-4-8
UPSTREAM_SYNC_ANTHROPIC_CHILD_MODEL=claude-sonnet-4-6

# OpenAI via Codex CLI (optional) — set UPSTREAM_SYNC_AGENT=openai
OPENAI_API_KEY=
UPSTREAM_SYNC_OPENAI_MODEL=gpt-5.5

# Git / GitHub
UPSTREAM_REMOTE=upstream
UPSTREAM_REPO=simstudioai/sim
UPSTREAM_BRANCH=main
TARGET_BRANCH=version-4.2-main
GITHUB_REPOSITORY=

# Comma-separated GitHub usernames requested as PR reviewers (not emails)
UPSTREAM_SYNC_PR_REVIEWERS=

# OAuth alternative for local Claude Code (instead of ANTHROPIC_API_KEY)
# CLAUDE_CODE_OAUTH_TOKEN=
